*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Logs and temporary files
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig
tmp/
temp/
.tmp/
